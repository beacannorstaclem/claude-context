{
  "name": "claude-context",
  "version": "0.1.0",
  "description": "A tool to manage and inject context into Claude AI conversations using vector search",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-context": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "context",
    "vector-search",
    "milvus",
    "zilliz",
    "ai",
    "llm",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zilliztech/claude-context.git"
  },
  "bugs": {
    "url": "https://github.com/zilliztech/claude-context/issues"
  },
  "homepage": "https://github.com/zilliztech/claude-context#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@zilliz/milvus2-sdk-node": "^2.4.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "glob": "^10.4.0",
    "tiktoken": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
